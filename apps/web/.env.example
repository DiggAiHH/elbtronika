# Copy to .env.local for local development
# NEVER commit .env.local to git
#
# For Doppler-managed environments, run:
#   doppler run --config prd -- pnpm dev
#
# Validate Doppler config:
#   PowerShell: doppler run --config prd -- pwsh scripts/validate-doppler-prd.ps1
#   Bash:       doppler run --config prd -- bash scripts/validate-doppler-prd.sh

# ── Core ──────────────────────────────────────────────
ELT_MODE=demo                       # demo | staging | live
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000   # legacy alias, optional

# ── Supabase ──────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key    # optional for client-only dev

# ── Stripe ────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...                 # optional in demo
STRIPE_CONNECT_REDIRECT_URL=http://localhost:3000/connect/return  # optional in demo

# ── Sanity CMS ────────────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_READ_TOKEN=your-read-token              # optional for public pages
SANITY_API_TOKEN=your-api-token                    # optional
SANITY_WEBHOOK_SECRET=your-webhook-secret          # optional

# ── Cloudflare R2 (optional in demo) ──────────────────
CLOUDFLARE_R2_ACCOUNT_ID=...
CLOUDFLARE_R2_ACCESS_KEY_ID=...
CLOUDFLARE_R2_SECRET_ACCESS_KEY=...
CLOUDFLARE_R2_BUCKET=...
CLOUDFLARE_R2_PUBLIC_URL=https://...

# ── AI & Messaging (optional) ─────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
RESEND_API_KEY=re_...                              # optional

# ── Monitoring & Trust (optional) ─────────────────────
SENTRY_DSN=https://...                             # optional
MCP_AUDIT_DB=false                                 # true = persist audit log to DB
