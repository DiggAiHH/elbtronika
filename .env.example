# ELBTRONIKA – Environment Variables
# Copy to .env.local for local dev. NEVER commit real values.
# Inject via Doppler in CI/CD (Phase 3+)

# Supabase (Phase 3)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (Phase 10) – TEST keys until Phase 15 go-live
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Anthropic (Phase 11)
ANTHROPIC_API_KEY=

# Sanity (Phase 3)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=

# Cloudflare R2 (Phase 3)
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=elbtronika-assets
NEXT_PUBLIC_CDN_URL=https://cdn.elbtronika.art

# Sentry (Phase 12)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
